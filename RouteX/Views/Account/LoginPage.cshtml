@model RouteX.Models.User
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>RouteX - Login</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 100%);
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            position: relative;
        }
       
        .bg-truck {
            position: absolute;
            opacity: 0.03;
            color: #ff6b35;
            font-size: 120px;
            animation: moveTruck 25s linear infinite;
        }

        .bg-truck:nth-child(1) { top: 10%; animation-delay: 0s; }
        .bg-truck:nth-child(2) { top: 40%; animation-delay: 8s; }
        .bg-truck:nth-child(3) { top: 70%; animation-delay: 16s; }

        @@keyframes moveTruck {
            0% { left: -150px; }
            100% { left: 100%; }
        }
      
        .login-container {
            background: white;
            border-radius: 20px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
            overflow: hidden;
            display: flex;
            width: 900px;
            max-width: 95%;
            height: 550px;
            position: relative;
            z-index: 10;
        }

        .login-left {
            flex: 1;
            background: linear-gradient(135deg, #ff9966 0%, #ff7d47 100%);
            padding: 50px 40px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            color: white;
            position: relative;
            overflow: hidden;
        }

        .login-left::before {
            content: '';
            position: absolute;
            width: 300px;
            height: 300px;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 50%;
            top: -100px;
            right: -100px;
        }

        .login-left::after {
            content: '';
            position: absolute;
            width: 200px;
            height: 200px;
            background: rgba(255, 255, 255, 0.08);
            border-radius: 50%;
            bottom: -50px;
            left: -50px;
        }

        .brand-content {
            position: relative;
            z-index: 2;
            text-align: center;
        }

        .logo-section {
            margin-bottom: 30px;
        }

        .logo-section h1 {
            font-size: 56px;
            font-weight: 800;
            letter-spacing: -2px;
            margin-bottom: 10px;
            text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.2);
        }

        .logo-image {
            width: 180px;
            height: auto;
            margin-bottom: 20px;
            animation: bounce 2s infinite;
        }

        @@keyframes bounce {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-10px); }
        }

        .description {
            font-size: 15px;
            line-height: 1.6;
            opacity: 0.95;
            max-width: 320px;
        }

        .login-right {
            flex: 1;
            padding: 50px 45px;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .login-header {
            margin-bottom: 35px;
        }

        .login-header h2 {
            color: #1a1a1a;
            font-size: 28px;
            font-weight: 700;
            margin-bottom: 8px;
        }

        .login-header p {
            color: #6c757d;
            font-size: 14px;
        }

        .form-group {
            margin-bottom: 22px;
        }

        .form-group label {
            display: block;
            color: #1a1a1a;
            font-weight: 600;
            font-size: 13px;
            margin-bottom: 8px;
        }

        .input-wrapper {
            position: relative;
        }

        .input-wrapper i {
            position: absolute;
            left: 14px;
            top: 50%;
            transform: translateY(-50%);
            color: #6c757d;
            font-size: 16px;
        }

        .form-group input {
            width: 100%;
            padding: 13px 14px 13px 42px;
            border: 1px solid #e9ecef;
            border-radius: 8px;
            font-size: 14px;
            transition: all 0.2s ease;
            color: #1a1a1a;
        }

        .form-group input:focus {
            outline: none;
            border-color: #ff6b35;
            box-shadow: 0 0 0 3px rgba(255, 107, 53, 0.1);
        }

        .error-message {
            color: #dc3545;
            font-size: 12px;
            margin-top: 6px;
            display: none;
        }

        .error-message.show {
            display: block;
        }

        .btn-login {
            width: 100%;
            padding: 14px;
            background: linear-gradient(135deg, #ff6b35 0%, #e55a2b 100%);
            color: white;
            border: none;
            border-radius: 8px;
            font-size: 15px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            margin-top: 10px;
        }

        .btn-login:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(255, 107, 53, 0.3);
        }

        .btn-login:active {
            transform: translateY(0);
        }


        @@media (max-width: 768px) {
            body {
                height: 100vh;
                min-height: 100vh;
                overflow: auto;
                padding: 10px;
                align-items: flex-start;
                justify-content: center;
            }

            .login-container {
                flex-direction: column;
                height: auto;
                min-height: auto;
                width: 100%;
                max-width: 400px;
                margin: 10px 0;
            }

            .login-left {
                padding: 20px 15px;
                min-height: auto;
            }

            .logo-section h1 {
                font-size: 32px;
            }

            .logo-image {
                width: 80px;
                margin-bottom: 15px;
            }

            .description {
                font-size: 13px;
                max-width: 280px;
            }

            .login-right {
                padding: 25px 20px;
            }

            .login-header h2 {
                font-size: 22px;
                margin-bottom: 6px;
            }

            .login-header p {
                font-size: 12px;
            }

            .form-group {
                margin-bottom: 18px;
            }

            .form-group input {
                padding: 12px 12px 12px 38px;
                font-size: 13px;
            }

            .btn-login {
                padding: 12px;
                font-size: 14px;
            }
        }

        @@media (max-width: 480px) {
            body {
                padding: 5px;
            }

            .login-container {
                max-width: 100%;
                margin: 5px 0;
            }

            .login-left {
                padding: 15px 10px;
            }

            .login-right {
                padding: 20px 15px;
            }

            .logo-section h1 {
                font-size: 28px;
            }

            .logo-image {
                width: 60px;
            }
        }
    </style>
</head>
<body>

    <i class="fas fa-truck bg-truck"></i>
    <i class="fas fa-truck bg-truck"></i>
    <i class="fas fa-truck bg-truck"></i>

    <div class="login-container">

        <div class="login-left">
            <div class="brand-content">
                <div class="logo-section">
                    <img src="~/routexlogo.png" alt="RouteX Logo" class="logo-image" />
                    <h1>RouteX</h1>
                </div>
                <p class="description">
                    Your smart fleet management system for tracking vehicles, maintenance, and expenses in one place.
                </p>
            </div>
        </div>


        <div class="login-right">
            <div class="login-header">
                <h2>Welcome Back!</h2>
                <p>Please login to access your dashboard</p>
            </div>

            <form asp-action="Login" asp-controller="Account" method="post" id="loginForm">
                <div class="form-group">
                    <label asp-for="Email">Email Address</label>
                    <div class="input-wrapper">
                        <i class="fas fa-envelope"></i>
                        <input asp-for="Email" type="email" id="email" placeholder="Enter your email" required />
                    </div>
                    <span class="error-message" id="emailError">Please enter a valid email</span>
                </div>

                <div class="form-group">
                    <label asp-for="Password">Password</label>
                    <div class="input-wrapper">
                        <i class="fas fa-lock"></i>
                        <input asp-for="Password" type="password" id="password" placeholder="Enter your password" required />
                    </div>
                    <span class="error-message" id="passwordError">Please enter your password</span>
                </div>

                @if (ViewBag.ErrorMessage != null)
                {
                    <div style="background: #fee; border: 1px solid #fcc; color: #c33; padding: 12px; border-radius: 6px; margin-bottom: 15px; font-size: 13px;">
                        <i class="fas fa-exclamation-circle"></i> @ViewBag.ErrorMessage
                    </div>
                }

                <button type="submit" class="btn-login">
                    <i class="fas fa-sign-in-alt"></i> Login
                </button>

            </form>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const form = document.getElementById('loginForm');
            const emailInput = document.getElementById('email');
            const passwordInput = document.getElementById('password');

            form.addEventListener('submit', function(e) {
                let isValid = true;

                // Email validation
                if (!emailInput.value.trim() || !validateEmail(emailInput.value)) {
                    document.getElementById('emailError').classList.add('show');
                    isValid = false;
                } else {
                    document.getElementById('emailError').classList.remove('show');
                }

                // Password validation
                if (!passwordInput.value.trim()) {
                    document.getElementById('passwordError').classList.add('show');
                    isValid = false;
                } else {
                    document.getElementById('passwordError').classList.remove('show');
                }

                if (!isValid) {
                    e.preventDefault();
                }
            });

            function validateEmail(email) {
                const re = /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/;
                return re.test(email);
            }

            // Clear error on input
            emailInput.addEventListener('input', function() {
                document.getElementById('emailError').classList.remove('show');
            });

            passwordInput.addEventListener('input', function() {
                document.getElementById('passwordError').classList.remove('show');
            });
        });
    </script>
</body>
</html>
