@using Microsoft.AspNetCore.Http
@{
    var userRole = Context.Session.GetString("UserRole") ?? "Administrator";
    var userName = Context.Session.GetString("UserName") ?? "Admin User";
    var isOperationsStaff = userRole == "OperationsStaff";
    var isSuperAdmin = userRole == "SuperAdmin";
    var isFinance = userRole == "Finance";
    var isAdmin = userRole == "Admin" || userRole == "Administrator";
    var showBudget = isFinance || isAdmin || isSuperAdmin;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - RouteX</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/RouteX.styles.css" asp-append-version="true" />
</head>
<body>
    <div class="app-container">        
        <!-- Sidebar -->
        <nav class="sidebar" id="sidebar">
            <div class="sidebar-header">
                <div class="sidebar-brand-container">
                    <img src="~/routexlogo.png" alt="RouteX Logo" class="sidebar-logo" id="sidebarLogoToggle" />
                    <span class="sidebar-brand">
                        <span class="route-text">Route</span><span class="x-text">X</span>
                    </span>
                </div>
                <button class="sidebar-collapse-btn" id="sidebarCollapseBtn">
                    <i class="fas fa-chevron-left"></i>
                </button>
            </div>
            
            <ul class="sidebar-menu">
                <li class="menu-item">
                    <a href="@Url.Action(isOperationsStaff ? "OpStaffDashboard" : (isFinance || isAdmin ? "FinanceDashboard" : "Index"), "Home")" class="menu-link @((ViewData["Title"]?.ToString() == "Dashboard" || ViewData["Title"]?.ToString() == "Operations Dashboard" || ViewData["Title"]?.ToString() == "Finance Dashboard") ? "active" : "")">
                        <i class="fas fa-tachometer-alt menu-icon"></i>
                        <span class="menu-text">Dashboard</span>
                    </a>
                </li>
                
                <!-- Vehicles, Fuel, Maintenance - Available to all users except Finance -->
                @if (!isFinance)
                {
                <li class="menu-item">
                    <a href="@Url.Action("VehiclePage", "Vehicles")" class="menu-link @(ViewData["Title"]?.ToString() == "Vehicle Management" ? "active" : "")">
                        <i class="fas fa-truck menu-icon"></i>
                        <span class="menu-text">Vehicles</span>
                    </a>
                </li>
                <li class="menu-item">
                    <a href="@Url.Action("FuelPage", "Fuel")" class="menu-link @(ViewData["Title"]?.ToString() == "Fuel Management" ? "active" : "")">
                        <i class="fas fa-gas-pump menu-icon"></i>
                        <span class="menu-text">Fuel</span>
                    </a>
                </li>
                <li class="menu-item">
                    <a href="@Url.Action("MaintenancePage", "Maintenance")" class="menu-link @(ViewData["Title"]?.ToString() == "Maintenance Schedule" ? "active" : "")">
                        <i class="fas fa-wrench menu-icon"></i>
                        <span class="menu-text">Maintenance</span>
                    </a>
                </li>
                }
                
                <!-- Finance - Available to all users except Operations Staff -->
                @if (!isOperationsStaff)
                {
                <li class="menu-item">
                    <a href="@Url.Action("FinancePage", "Finance")" class="menu-link @(ViewData["Title"]?.ToString() == "Finance" ? "active" : "")">
                        <i class="fas fa-dollar-sign menu-icon"></i>
                        <span class="menu-text">Finance</span>
                    </a>
                </li>
                @if (showBudget)
                {
                <li class="menu-item">
                    <a href="@Url.Action("Index", "Budget")" class="menu-link @(ViewData["Title"]?.ToString() == "Budget" ? "active" : "")">
                        <i class="fas fa-wallet menu-icon"></i>
                        <span class="menu-text">Budget</span>
                    </a>
                </li>
                }
                }
                
                <!-- Reports - Available to all users except Operations Staff -->
                @if (!isOperationsStaff)
                {
                <li class="menu-item">
                    <a href="@Url.Action("ReportsPage", "Reports")" class="menu-link @(ViewData["Title"]?.ToString() == "Reports" ? "active" : "")">
                        <i class="fas fa-chart-bar menu-icon"></i>
                        <span class="menu-text">Reports</span>
                    </a>
                </li>
                }
                
                <!-- Users and Audit - Super Admin only -->
                @if (isSuperAdmin)
                {
                <li class="menu-item">
                    <a href="@Url.Action("AuditPage", "Audit")" class="menu-link @(ViewData["Title"]?.ToString() == "Audit Logs" ? "active" : "")">
                        <i class="fas fa-clipboard-list menu-icon"></i>
                        <span class="menu-text">Audit</span>
                    </a>
                </li>
                <li class="menu-item">
                    <a href="@Url.Action("UsersPage", "Users")" class="menu-link @(ViewData["Title"]?.ToString() == "Users List" ? "active" : "")">
                        <i class="fas fa-users menu-icon"></i>
                        <span class="menu-text">Users</span>
                    </a>
                </li>
                <li class="menu-item">
                    <a href="@Url.Action("ArchivePage", "Archive")" class="menu-link @(ViewData["Title"]?.ToString() == "Archive" ? "active" : "")">
                        <i class="fas fa-archive menu-icon"></i>
                        <span class="menu-text">Archive</span>
                    </a>
                </li>
                }
            </ul>
            
            <div class="sidebar-footer">
                <a href="@Url.Action("Logout", "Account")" class="logout-btn">
                    <i class="fas fa-sign-out-alt menu-icon"></i>
                    <span class="menu-text">Logout</span>
                </a>
            </div>
        </nav>

        <!-- Main Content Area -->
        <div class="main-content">
            <!-- Topbar -->
            <header class="topbar">
                <div class="topbar-content">
                    <!-- Mobile Menu Toggle - moved to topbar -->
                    <button class="mobile-menu-toggle-topbar" id="mobileMenuToggle">
                        <i class="fas fa-bars"></i>
                    </button>
                    <h1 class="page-title">@ViewData["Title"]</h1>
                    <div class="topbar-actions">
                        <div class="user-menu">
                            <i class="fas fa-user-circle user-avatar"></i>
                            <span class="user-name">@userName</span>
                        </div>
                    </div>
                </div>
            </header>

            <!-- Page Content -->
            <main class="content-area">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const sidebar = document.getElementById('sidebar');
            const collapseIcon = document.querySelector('#sidebarCollapseBtn i');
            const isCollapsed = localStorage.getItem('sidebarCollapsed') === 'true';
            
            if (isCollapsed) {
                sidebar.classList.add('collapsed');
                collapseIcon.classList.remove('fa-chevron-left');
                collapseIcon.classList.add('fa-chevron-right');
            }
            
            // Mobile menu toggle functionality
            const mobileMenuToggle = document.getElementById('mobileMenuToggle');
            if (mobileMenuToggle) {
                mobileMenuToggle.addEventListener('click', function() {
                    sidebar.classList.toggle('mobile-open');
                    // Hide mobile menu button when sidebar is opened
                    updateMobileMenuToggleVisibility();
                });
            }

            // Function to show/hide mobile menu toggle based on sidebar state
            function updateMobileMenuToggleVisibility() {
                if (window.innerWidth <= 768 && mobileMenuToggle) {
                    const isSidebarOpen = sidebar.classList.contains('mobile-open');
                    if (isSidebarOpen) {
                        mobileMenuToggle.style.display = 'none';
                    } else {
                        mobileMenuToggle.style.display = 'block';
                    }
                }
            }

            // Close mobile menu when clicking outside
            document.addEventListener('click', function(event) {
                if (window.innerWidth <= 768) {
                    if (!sidebar.contains(event.target) && !mobileMenuToggle.contains(event.target)) {
                        sidebar.classList.remove('mobile-open');
                        updateMobileMenuToggleVisibility();
                    }
                }
            });

            // Handle sidebar collapse in mobile view
            document.getElementById('sidebarCollapseBtn').addEventListener('click', function() {
                if (window.innerWidth <= 768) {
                    // In mobile view, close the sidebar completely instead of collapsing
                    sidebar.classList.remove('mobile-open');
                } else {
                    toggleSidebar();
                }
                updateMobileMenuToggleVisibility();
            });
            
            document.getElementById('sidebarLogoToggle').addEventListener('click', function() {
                if (window.innerWidth <= 768) {
                    const wasMobileOpen = sidebar.classList.contains('mobile-open');
                    if (sidebar.classList.contains('collapsed')) {
                        sidebar.classList.remove('collapsed');
                        if (wasMobileOpen) {
                            sidebar.classList.add('mobile-open');
                        }
                    }
                } else {
                    if (sidebar.classList.contains('collapsed')) {
                        toggleSidebar();
                    }
                }
                updateMobileMenuToggleVisibility();
            });

            // Initialize mobile menu toggle visibility
            updateMobileMenuToggleVisibility();
        });
        
        function toggleSidebar() {
            const sidebar = document.getElementById('sidebar');
            const collapseIcon = document.querySelector('#sidebarCollapseBtn i');
            sidebar.classList.toggle('collapsed');
            const isCollapsed = sidebar.classList.contains('collapsed');
            localStorage.setItem('sidebarCollapsed', isCollapsed.toString());
            
            if (isCollapsed) {
                collapseIcon.classList.remove('fa-chevron-left');
                collapseIcon.classList.add('fa-chevron-right');
            } else {
                collapseIcon.classList.remove('fa-chevron-right');
                collapseIcon.classList.add('fa-chevron-left');
            }
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
