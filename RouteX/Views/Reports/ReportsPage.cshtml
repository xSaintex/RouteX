@model RouteX.Controllers.ReportsViewModel
@{
    ViewData["Title"] = "Reports";
}

@Html.AntiForgeryToken()

<style>
/* Reports table badge styles: no background, only colored text */
.expense-type-badge { background: transparent !important; padding: 0 !important; border: none !important; box-shadow: none !important; font-weight:600; }
.expense-fuel { color: #ff7a00 !important; }
.expense-maintenance { color: #ffb300 !important; }
.expense-other { color: #6c757d !important; }
.pagination-info { color:#333; }

/* Chart container styles */
.chart-canvas {
    height: 300px;
    margin-top: 20px;
}

.chart-container {
    min-height: 400px;
}
</style>


<!-- Report Filters Section -->
<div class="finance-section">
    <h3>Report Filters</h3>
    <div class="filter-row">
        <div class="filter-group">
            <label for="reportType">Report Type</label>
            <select id="reportType" class="form-control">
                @foreach (var type in Model.ReportTypes)
                {
                    <option value="@type" selected="@(Model.SelectedReportType == type)">@type</option>
                }
            </select>
        </div>
        
        <div class="filter-group">
            <label for="dateRange">Date Range</label>
            <select id="dateRange" class="form-control" onchange="toggleDateRange(this.value)">
                <option value="Last 7 Days" selected>Last 7 Days</option>
                <option value="Last 30 Days">Last 30 Days</option>
                <option value="Last 3 Months">Last 3 Months</option>
                <option value="Last 6 Months">Last 6 Months</option>
                <option value="Last Year">Last Year</option>
                <option value="Custom Range">Custom Range</option>
            </select>
        </div>
        
        <div id="customDateRange" class="filter-group" style="display: none;">
            <label for="startDate">Start Date</label>
            <input type="date" id="startDate" class="form-control" style="min-width: 140px;">
        </div>
        
        <div id="customDateRangeEnd" class="filter-group" style="display: none;">
            <label for="endDate">End Date</label>
            <input type="date" id="endDate" class="form-control" style="min-width: 140px;">
        </div>
        
        <div class="filter-group">
            <label>&nbsp;</label>
            <button class="btn btn-orange" onclick="exportToPDF()">
                <i class="fas fa-file-pdf"></i>
                Export PDF
            </button>
        </div>
    </div>
</div>

<!-- Summary Cards Section -->
<div class="finance-summary-grid">
    <a href="@Url.Action("TotalExpensesAllTime", "Finance")" class="finance-card-link">
        <div class="finance-card clickable-card">
            <div class="finance-card-icon">
                <i class="fas fa-dollar-sign"></i>
            </div>
            <div class="finance-card-content">
                <h3>@Model.TotalExpenses.ToString("C2")</h3>
                <p>Total Expenses (All-Time)</p>
            </div>
        </div>
    </a>

    <a href="@Url.Action("TotalFuel", "Finance")" class="finance-card-link">
        <div class="finance-card clickable-card">
            <div class="finance-card-icon">
                <i class="fas fa-gas-pump"></i>
            </div>
            <div class="finance-card-content">
                <h3>@Model.TotalFuelCost.ToString("C2")</h3>
                <p>Total Fuel Cost</p>
            </div>
        </div>
    </a>

    <a href="@Url.Action("TotalMaintenance", "Finance")" class="finance-card-link">
        <div class="finance-card clickable-card">
            <div class="finance-card-icon">
                <i class="fas fa-wrench"></i>
            </div>
            <div class="finance-card-content">
                <h3>@Model.TotalMaintenanceCost.ToString("C2")</h3>
                <p>Total Maintenance Cost</p>
            </div>
        </div>
    </a>
</div>

<!-- Chart Section -->
<div class="finance-section">
    <div class="section-header">
        <h3>Report Visualization</h3>
        <div class="export-actions">
            <button class="btn btn-orange" onclick="exportChartsPdf()">
                <i class="fas fa-file-pdf"></i>
                Export PDF
            </button>
        </div>
    </div>
    <div class="finance-charts">
        <div class="chart-container">
            <h3>Expense Trends</h3>
            <div class="chart-canvas">
                <canvas id="expenseTrendsChart"></canvas>
            </div>
        </div>

        <div class="chart-container">
            <h3>Monthly Total Cost vs Budget</h3>
            <div class="chart-canvas">
                <canvas id="budgetComparisonChart"></canvas>
            </div>
        </div>
    </div>
</div>

<script>
function toggleDateRange(value) {
    const customDateRange = document.getElementById('customDateRange');
    const customDateRangeEnd = document.getElementById('customDateRangeEnd');
    
    if (value === 'Custom Range') {
        customDateRange.style.display = 'block';
        customDateRangeEnd.style.display = 'block';
    } else {
        customDateRange.style.display = 'none';
        customDateRangeEnd.style.display = 'none';
    }
}

function getReportFilters() {
    return {
        reportType: document.getElementById('reportType').value,
        dateRange: document.getElementById('dateRange').value,
        startDate: document.getElementById('startDate').value,
        endDate: document.getElementById('endDate').value
    };
}

// Client-side pagination for reports table (matches maintenance table behavior)
document.addEventListener('DOMContentLoaded', function () {
    let currentPage = 1;
    const itemsPerPage = 10;
    const tbody = document.getElementById('reportTableBody');
    const allRows = Array.from(tbody.getElementsByClassName('report-row'));

    function renderRowsForPage(rows) {
        allRows.forEach(r => r.style.display = 'none');
        const startIdx = (currentPage - 1) * itemsPerPage;
        const endIdx = startIdx + itemsPerPage;
        rows.forEach((r, i) => { if (i >= startIdx && i < endIdx) r.style.display = ''; });
    }

    function updatePagination(visibleCount) {
        const info = document.querySelector('.pagination-info');
        const start = (currentPage - 1) * itemsPerPage + 1;
        const end = Math.min(visibleCount, currentPage * itemsPerPage);
        info.textContent = visibleCount === 0 ? 'Showing 0 of 0 entries' : `Showing ${start}-${end} of ${visibleCount} entries`;

        const prevBtn = document.querySelector('.pagination-controls .prev');
        const nextBtn = document.querySelector('.pagination-controls .next');
        prevBtn.style.display = currentPage > 1 ? '' : 'none';
        nextBtn.style.display = visibleCount > currentPage * itemsPerPage ? '' : 'none';

        const pageNumberBtn = document.querySelector('.pagination-controls .page-number');
        pageNumberBtn.textContent = currentPage.toString();
    }

    function refresh() {
        const visibleRows = allRows; // no filters here; show all rows paged
        renderRowsForPage(visibleRows);
        updatePagination(visibleRows.length);
    }

    document.querySelector('.pagination-controls .prev').addEventListener('click', function () { if (currentPage > 1) { currentPage--; refresh(); } });
    document.querySelector('.pagination-controls .next').addEventListener('click', function () { const totalVisible = allRows.length; const maxPage = Math.max(1, Math.ceil(totalVisible / itemsPerPage)); if (currentPage < maxPage) { currentPage++; refresh(); } });

    // Initial
    currentPage = 1; refresh();
});

function updateSummaryCards(reportType) {
    // This would typically make an AJAX call to get updated data
    // For now, we'll just update the display
    console.log('Updating summary cards for:', reportType);
}

async function exportToPDF() {
    const { reportType, dateRange, startDate, endDate } = getReportFilters();

    showNotification('Exporting to PDF...', 'info');

    const params = new URLSearchParams({ reportType, dateRange });
    if (dateRange === 'Custom Range' && startDate && endDate) {
        params.append('startDate', startDate);
        params.append('endDate', endDate);
    }

    const response = await fetch(`@Url.Action("ReportData", "Reports")?${params.toString()}`);
    if (!response.ok) {
        showNotification('Unable to export report.', 'info');
        return;
    }

    const records = await response.json();
    const { jsPDF } = window.jspdf;
    const doc = new jsPDF();

    doc.setFontSize(16);
    doc.text(`${reportType} Report`, 14, 16);
    doc.setFontSize(11);
    doc.text(`Date Range: ${dateRange}`, 14, 24);

    const tableRows = records.map(r => [
        `#${r.id}`,
        r.vehicle,
        r.category,
        Number(r.amount).toFixed(2),
        r.date || '-',
        r.description
    ]);

    doc.autoTable({
        head: [["Record ID", "Vehicle", "Category", "Amount", "Date", "Description"]],
        body: tableRows,
        startY: 30
    });

    doc.save(`${reportType}_Report.pdf`);
    await logReportExport('PDF');
    showNotification('PDF exported successfully!', 'success');
}

function exportChartsPdf() {
    const { jsPDF } = window.jspdf;
    const doc = new jsPDF();

    doc.setFontSize(16);
    doc.text('Report Visualization', 14, 16);

    const expenseCanvas = document.getElementById('expenseTrendsChart');
    if (expenseCanvas) {
        const expenseImage = expenseCanvas.toDataURL('image/png');
        doc.addImage(expenseImage, 'PNG', 14, 24, 180, 80);

        doc.setFontSize(12);
        doc.text('Expense Trends Details', 14, 112);
        doc.setFontSize(10);
        let y = 120;
        expenseTrendData.forEach(item => {
            const line = `${item.Month}: Fuel PHP ${item.FuelCost.toLocaleString()} | Maintenance PHP ${item.MaintenanceCost.toLocaleString()} | Other PHP ${item.OtherCost.toLocaleString()}`;
            doc.text(line, 14, y);
            y += 6;
            if (y > 190) {
                doc.addPage();
                y = 20;
            }
        });
    }

    doc.addPage();
    const budgetCanvas = document.getElementById('budgetComparisonChart');
    if (budgetCanvas) {
        const budgetImage = budgetCanvas.toDataURL('image/png');
        doc.addImage(budgetImage, 'PNG', 14, 20, 180, 80);

        doc.setFontSize(12);
        doc.text('Monthly Total Cost vs Budget Details', 14, 110);
        doc.setFontSize(10);
        let y = 118;
        expenseTrendData.forEach(item => {
            const budget = budgetLookup.get(item.Month) || 0;
            const line = `${item.Month}: Total PHP ${item.TotalCost.toLocaleString()} | Budget PHP ${budget.toLocaleString()}`;
            doc.text(line, 14, y);
            y += 6;
            if (y > 190) {
                doc.addPage();
                y = 20;
            }
        });
    }

    doc.save('ReportVisualization.pdf');
}

async function logReportExport(format) {
    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
    if (!token) {
        return;
    }

    await fetch('@Url.Action("LogExport", "Reports")', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
            'RequestVerificationToken': token
        },
        body: new URLSearchParams({ format })
    });
}

function showNotification(message, type) {
    // Create notification element
    const notification = document.createElement('div');
    notification.className = `notification notification-${type}`;
    notification.innerHTML = `
        <i class="fas fa-${type === 'success' ? 'check-circle' : 'info-circle'}"></i>
        <span>${message}</span>
    `;
    
    // Add to page
    document.body.appendChild(notification);
    
    // Remove after 3 seconds
    setTimeout(() => {
        notification.remove();
    }, 3000);
}
</script>

<!-- Chart.js Library -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.29/jspdf.plugin.autotable.min.js"></script>

<script>
document.addEventListener('DOMContentLoaded', function() {
    // Expense Trends Chart
    const expenseTrendsCtx = document.getElementById('expenseTrendsChart').getContext('2d');
    
    window.expenseTrendData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MonthlyExpenseBreakdown));
    const monthlyBudgets = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MonthlyBudgets));
    window.budgetLookup = new Map(monthlyBudgets.map(b => [b.Month, b.BudgetAmount]));
    
    new Chart(expenseTrendsCtx, {
        type: 'line',
        data: {
            labels: window.expenseTrendData.map(d => d.Month),
            datasets: [
                {
                    label: 'Fuel Expenses',
                    data: window.expenseTrendData.map(d => d.FuelCost),
                    borderColor: '#ff7a00',
                    backgroundColor: 'rgba(255, 122, 0, 0.1)',
                    borderWidth: 2,
                    tension: 0.4
                },
                {
                    label: 'Maintenance Expenses',
                    data: window.expenseTrendData.map(d => d.MaintenanceCost),
                    borderColor: '#ffb300',
                    backgroundColor: 'rgba(255, 179, 0, 0.1)',
                    borderWidth: 2,
                    tension: 0.4
                },
                {
                    label: 'Other Expenses',
                    data: window.expenseTrendData.map(d => d.OtherCost),
                    borderColor: '#6c757d',
                    backgroundColor: 'rgba(108, 117, 125, 0.1)',
                    borderWidth: 2,
                    tension: 0.4
                }
            ]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            interaction: {
                mode: 'index',
                intersect: false,
            },
            scales: {
                x: {
                    display: true,
                    title: {
                        display: true,
                        text: 'Month'
                    }
                },
                y: {
                    display: true,
                    title: {
                        display: true,
                        text: 'Amount (₱)'
                    }
                }
            },
            plugins: {
                legend: {
                    display: true,
                    position: 'top'
                }
            }
        }
    });

    // Category Breakdown Chart
    const budgetComparisonCtx = document.getElementById('budgetComparisonChart').getContext('2d');

    new Chart(budgetComparisonCtx, {
        type: 'bar',
        data: {
            labels: window.expenseTrendData.map(d => d.Month),
            datasets: [
                {
                    label: 'Total Cost',
                    data: window.expenseTrendData.map(d => d.TotalCost),
                    backgroundColor: 'rgba(255, 122, 0, 0.4)',
                    borderColor: '#ff7a00',
                    borderWidth: 1
                },
                {
                    label: 'Budget',
                    type: 'line',
                    data: window.expenseTrendData.map(d => window.budgetLookup.get(d.Month) || 0),
                    borderColor: '#1976d2',
                    borderWidth: 2,
                    fill: false,
                    tension: 0.3
                }
            ]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            scales: {
                y: {
                    title: {
                        display: true,
                        text: 'Amount (₱)'
                    }
                }
            },
            plugins: {
                legend: {
                    position: 'top'
                }
            }
        }
    });
});
</script>

<style>
.notification {
    position: fixed;
    top: 20px;
    right: 20px;
    padding: 15px 20px;
    border-radius: 8px;
    color: white;
    font-weight: 500;
    z-index: 1000;
    display: flex;
    align-items: center;
    gap: 10px;
    animation: slideInRight 0.3s ease;
}

.notification-success {
    background: #28a745;
}

.notification-info {
    background: #17a2b8;
}

</style>
