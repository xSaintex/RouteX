@model List<RouteX.Models.ExpenseTimeSeriesData>
@{
    ViewData["Title"] = "Total Expenses (All-Time)";
}

@Html.AntiForgeryToken()

<style>
.chart-container-full {
    background: white;
    border-radius: 12px;
    padding: 24px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.06);
    border: 1px solid #e9ecef;
    margin-bottom: 24px;
}

.chart-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 24px;
}

.chart-title {
    font-size: 20px;
    font-weight: 600;
    color: #2c3e50;
}

.chart-subtitle {
    font-size: 14px;
    color: #6c757d;
    margin-top: 4px;
}

.chart-canvas {
    height: 400px;
    position: relative;
}

.chart-legend {
    display: flex;
    justify-content: center;
    gap: 24px;
    margin-top: 20px;
    flex-wrap: wrap;
}

.legend-item {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    color: #495057;
}

.legend-color {
    width: 12px;
    height: 12px;
    border-radius: 2px;
}

.chart-stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 16px;
    margin-top: 24px;
}

.stat-card {
    background: #f8f9fa;
    border-radius: 8px;
    padding: 16px;
    border-left: 4px solid #ff6b35;
}

.stat-label {
    font-size: 12px;
    color: #6c757d;
    margin-bottom: 4px;
}

.stat-value {
    font-size: 18px;
    font-weight: 600;
    color: #2c3e50;
}

@@media (max-width: 768px) {
    .chart-container-full {
        padding: 16px;
    }
    
    .chart-header {
        flex-direction: column;
        align-items: flex-start;
        gap: 8px;
    }
    
    .chart-canvas {
        height: 300px;
    }
    
    .chart-stats {
        grid-template-columns: 1fr;
    }
}
</style>

<div class="vehicles-container">
    <button class="back-button-top-left" onclick="history.back()">
        <i class="fas fa-arrow-left"></i>
        Back
    </button>

    <div class="chart-container-full">
        <div class="chart-header">
            <div>
                <h2 class="chart-title">Total Expenses Over Time</h2>
                <p class="chart-subtitle">Monthly expense trends for the last 24 months</p>
            </div>
            
            <div class="chart-export-buttons">
                <button class="btn-export-small" onclick="exportToPDF()">
                    <i class="fas fa-file-pdf"></i>
                    Export PDF
                </button>
                <button class="btn-export-small" onclick="exportToCSV()">
                    <i class="fas fa-file-csv"></i>
                    Export CSV
                </button>
            </div>
        </div>

        <div class="chart-canvas">
            <canvas id="expensesTimeChart"></canvas>
        </div>

        <div class="chart-legend">
            <div class="legend-item">
                <div class="legend-color" style="background: #ff6b35;"></div>
                <span>Total Expenses</span>
            </div>
        </div>

        <div class="chart-stats">
            <div class="stat-card">
                <div class="stat-label">Total Expenses (All Time)</div>
                <div class="stat-value">₱@Model.Sum(d => d.ExpenseAmount).ToString("N0")</div>
            </div>
            <div class="stat-card">
                <div class="stat-label">Average Monthly</div>
                <div class="stat-value">₱@Model.Average(d => d.ExpenseAmount).ToString("N0")</div>
            </div>
            <div class="stat-card">
                <div class="stat-label">Highest Month</div>
                <div class="stat-value">₱@Model.Max(d => d.ExpenseAmount).ToString("N0") (@Model.OrderByDescending(d => d.ExpenseAmount).First().Month)</div>
            </div>
            <div class="stat-card">
                <div class="stat-label">Lowest Month</div>
                <div class="stat-value">₱@Model.Where(d => d.ExpenseAmount > 0).Min(d => d.ExpenseAmount).ToString("N0") (@Model.Where(d => d.ExpenseAmount > 0).OrderBy(d => d.ExpenseAmount).First().Month)</div>
            </div>
        </div>
    </div>
</div>

<!-- Chart.js Library -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<!-- jsPDF Library -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const timeSeriesData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model));
    
    const ctx = document.getElementById('expensesTimeChart').getContext('2d');
    
    new Chart(ctx, {
        type: 'line',
        data: {
            labels: timeSeriesData.map(d => d.Month),
            datasets: [
                {
                    label: 'Total Expenses',
                    data: timeSeriesData.map(d => d.ExpenseAmount),
                    borderColor: '#ff6b35',
                    backgroundColor: 'rgba(255, 107, 53, 0.1)',
                    borderWidth: 3,
                    tension: 0.4,
                    fill: true
                }
            ]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            interaction: {
                mode: 'index',
                intersect: false,
            },
            scales: {
                x: {
                    display: true,
                    title: {
                        display: true,
                        text: 'Month'
                    },
                    grid: {
                        display: false
                    }
                },
                y: {
                    display: true,
                    title: {
                        display: true,
                        text: 'Amount (₱)'
                    },
                    ticks: {
                        callback: function(value) {
                            return '₱' + value.toLocaleString();
                        }
                    }
                }
            },
            plugins: {
                legend: {
                    display: false // Hide default legend, using custom one
                },
                tooltip: {
                    callbacks: {
                        label: function(context) {
                            let label = context.dataset.label || '';
                            if (label) {
                                label += ': ';
                            }
                            if (context.parsed.y !== null) {
                                label += '₱' + context.parsed.y.toLocaleString('en-PH', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
                            }
                            return label;
                        }
                    }
                }
            }
        }
    });
});

function exportToPDF() {
    logFinanceExport('TotalExpensesAllTime', 'PDF');
    showNotification('Generating PDF...', 'info');
    
    // Get current chart data and statistics
    const timeSeriesData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model));
    const totalExpenses = @(Model.Sum(d => d.ExpenseAmount));
    const avgExpenses = @(Model.Average(d => d.ExpenseAmount));
    const highestMonthData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.OrderByDescending(d => d.ExpenseAmount).First()));
    const lowestMonthData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Where(d => d.ExpenseAmount > 0).OrderBy(d => d.ExpenseAmount).First()));
    
    // Create PDF content with chart image
    const { jsPDF } = window.jspdf;
    const doc = new jsPDF();
    
    // Add title
    doc.setFontSize(20);
    doc.text('Total Expenses (All-Time) Report', 20, 20);
    
    // Add date
    doc.setFontSize(12);
    doc.text('Generated: ' + new Date().toLocaleDateString(), 20, 30);
    
    // Capture and add chart image
    const chartCanvas = document.getElementById('expensesTimeChart');
    if (chartCanvas) {
        const chartImage = chartCanvas.toDataURL('image/png');
        doc.addImage(chartImage, 'PNG', 20, 40, 170, 100);
    }
    
    // Add statistics below chart
    doc.setFontSize(14);
    doc.text('Statistics Summary', 20, 150);
    doc.setFontSize(11);
    doc.text('Total Expenses: PHP ' + totalExpenses.toLocaleString('en-PH'), 20, 160);
    doc.text('Average Monthly: PHP ' + avgExpenses.toLocaleString('en-PH'), 20, 167);
    doc.text('Highest Month: PHP ' + highestMonthData.ExpenseAmount.toLocaleString('en-PH') + ' (' + highestMonthData.Month + ')', 20, 174);
    doc.text('Lowest Month: PHP ' + lowestMonthData.ExpenseAmount.toLocaleString('en-PH') + ' (' + lowestMonthData.Month + ')', 20, 181);
    
    // Add monthly data table
    doc.setFontSize(14);
    doc.text('Monthly Data (Last 24 Months)', 20, 195);
    doc.setFontSize(10);
    let yPos = 205;
    timeSeriesData.forEach(item => {
        doc.text(item.Month + ': PHP ' + item.ExpenseAmount.toLocaleString('en-PH'), 20, yPos);
        yPos += 7;
        if (yPos > 270) {
            doc.addPage();
            yPos = 20;
        }
    });
    
    // Save PDF
    doc.save('Expenses_Report_' + new Date().toISOString().split('T')[0] + '.pdf');
    showNotification('PDF exported successfully!', 'success');
}

function exportToCSV() {
    logFinanceExport('TotalExpensesAllTime', 'CSV');
    showNotification('Generating CSV...', 'info');
    
    // Get current chart data and statistics
    const timeSeriesData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model));
    const totalExpenses = @(Model.Sum(d => d.ExpenseAmount));
    const avgExpenses = @(Model.Average(d => d.ExpenseAmount));
    const highestMonthData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.OrderByDescending(d => d.ExpenseAmount).First()));
    const lowestMonthData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Where(d => d.ExpenseAmount > 0).OrderBy(d => d.ExpenseAmount).First()));
    
    // Create organized CSV content
    let csvContent = 'Total Expenses (All-Time) Report\n';
    csvContent += 'Generated,' + new Date().toLocaleDateString() + '\n\n';
    
    // Statistics Summary
    csvContent += 'Statistics Summary\n';
    csvContent += 'Total Expenses,₱' + totalExpenses.toLocaleString('en-PH') + '\n';
    csvContent += 'Average Monthly,₱' + avgExpenses.toLocaleString('en-PH') + '\n';
    csvContent += 'Highest Month,₱' + highestMonthData.ExpenseAmount.toLocaleString('en-PH') + ',' + highestMonthData.Month + '\n';
    csvContent += 'Lowest Month,₱' + lowestMonthData.ExpenseAmount.toLocaleString('en-PH') + ',' + lowestMonthData.Month + '\n\n';
    
    // Monthly Data Table
    csvContent += 'Monthly Data (Last 24 Months)\n';
    csvContent += 'Month,Expense Amount (₱)\n';
    timeSeriesData.forEach(item => {
        csvContent += item.Month + ',' + item.ExpenseAmount.toLocaleString('en-PH') + '\n';
    });
    
    // Create and download CSV file
    const blob = new Blob([csvContent], { type: 'text/csv;charset=utf-8;' });
    const link = document.createElement('a');
    const url = URL.createObjectURL(blob);
    link.setAttribute('href', url);
    link.setAttribute('download', 'Expenses_Report_' + new Date().toISOString().split('T')[0] + '.csv');
    link.style.visibility = 'hidden';
    document.body.appendChild(link);
    link.click();
    document.body.removeChild(link);
    
    showNotification('CSV exported successfully!', 'success');
}

function logFinanceExport(report, format) {
    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
    if (!token) {
        return;
    }

    fetch('@Url.Action("LogExport", "Finance")', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
            'RequestVerificationToken': token
        },
        body: new URLSearchParams({ report, format })
    });
}

function showNotification(message, type) {
    const notification = document.createElement('div');
    notification.className = `notification notification-${type}`;
    notification.innerHTML = `
        <i class="fas fa-${type === 'success' ? 'check-circle' : 'info-circle'}"></i>
        <span>${message}</span>
    `;
    
    document.body.appendChild(notification);
    
    setTimeout(() => {
        notification.remove();
    }, 3000);
}
</script>
