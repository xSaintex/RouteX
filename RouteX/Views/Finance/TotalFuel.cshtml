@{
    ViewData["Title"] = "Total Fuel Expenses";
}

@{
    string css = @"
.chart-container-full {
    background: white;
    border-radius: 12px;
    padding: 24px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.06);
    border: 1px solid #e9ecef;
    margin-bottom: 24px;
}

.chart-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 24px;
}

.chart-title {
    font-size: 20px;
    font-weight: 600;
    color: #2c3e50;
}

.chart-subtitle {
    font-size: 14px;
    color: #6c757d;
    margin-top: 4px;
}

.chart-canvas {
    height: 400px;
    position: relative;
}

.chart-tabs-top-right {
    position: absolute;
    top: 20px;
    right: 20px;
    display: flex;
    gap: 8px;
}

.tab-btn-modern {
    padding: 8px 16px;
    border: 1px solid #ddd;
    background: white;
    border-radius: 6px;
    cursor: pointer;
    font-size: 14px;
    transition: all 0.3s ease;
}

.tab-btn-modern:hover {
    background: #f8f9fa;
}

.tab-btn-modern.active {
    background: #ff6b35;
    color: white;
    border-color: #ff6b35;
}

.chart-stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 16px;
    margin-top: 24px;
}

.stat-card {
    background: #f8f9fa;
    border-radius: 8px;
    padding: 16px;
    border-left: 4px solid #ff6b35;
}

.stat-label {
    font-size: 12px;
    color: #6c757d;
    margin-bottom: 4px;
}

.stat-value {
    font-size: 18px;
    font-weight: 600;
    color: #2c3e50;
}

@media (max-width: 768px) {
    .chart-container-full {
        padding: 16px;
    }
    
    .chart-header {
        flex-direction: column;
        align-items: flex-start;
        gap: 8px;
    }
    
    .chart-canvas {
        height: 300px;
    }
    
    .chart-tabs-top-right {
        position: static;
        margin-bottom: 16px;
    }
    
    .chart-stats {
        grid-template-columns: 1fr;
    }
}";
}

<!DOCTYPE html>
<html>
<head>
    <title>@ViewData["Title"]</title>
    <style>@css</style>
</head>
<body>
    <div class="vehicles-container">
        <button class="back-button-top-left" onclick="history.back()">
            <i class="fas fa-arrow-left"></i>
            Back
        </button>

        <div class="chart-container-full">
            <div class="chart-header">
                <div>
                    <h2 class="chart-title">Fuel Expenses Analysis</h2>
                    <p class="chart-subtitle">Track fuel costs across different time periods</p>
                </div>
                
                <div class="chart-export-buttons">
                    <button class="btn-export-small" onclick="exportToPDF()">
                        <i class="fas fa-file-pdf"></i>
                        Export PDF
                    </button>
                    <button class="btn-export-small" onclick="exportToCSV()">
                        <i class="fas fa-file-csv"></i>
                        Export CSV
                    </button>
                </div>
            </div>

            <div class="chart-tabs-top-right">
                <button class="tab-btn-modern active" onclick="showTab('weekly')">Weekly</button>
                <button class="tab-btn-modern" onclick="showTab('monthly')">Monthly</button>
                <button class="tab-btn-modern" onclick="showTab('annually')">Annually</button>
            </div>

            <div class="chart-canvas">
                <canvas id="fuelChart"></canvas>
            </div>

            <div class="chart-legend">
                <div class="legend-item">
                    <div class="legend-color" style="background: #ff6b35;"></div>
                    <span>Fuel Cost</span>
                </div>
            </div>

            <div class="chart-stats">
                <div class="stat-card">
                    <div class="stat-label">Total Fuel Cost</div>
                    <div class="stat-value" id="totalFuelCost">?0</div>
                </div>
                <div class="stat-card">
                    <div class="stat-label">Average Fuel Cost</div>
                    <div class="stat-value" id="avgFuelCost">?0</div>
                </div>
                <div class="stat-card">
                    <div class="stat-label">Highest Period</div>
                    <div class="stat-value" id="highestFuelCost">?0</div>
                </div>
                <div class="stat-card">
                    <div class="stat-label">Lowest Period</div>
                    <div class="stat-value" id="lowestFuelCost">?0</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Chart.js Library -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
document.addEventListener('DOMContentLoaded', function() {
    const weeklyData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.WeeklyData));
    const monthlyData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.MonthlyData));
    const annualData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.AnnualData));
    
    let currentChart = null;
    let currentPeriod = 'weekly';
    
    // Show weekly chart by default
    showChart('weekly', weeklyData);
    updateStats(weeklyData);
});

function showTab(period) {
    const tabs = document.querySelectorAll('.tab-btn-modern');
    tabs.forEach(tab => tab.classList.remove('active'));
    event.target.classList.add('active');
    
    currentPeriod = period;
    
    const weeklyData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.WeeklyData));
    const monthlyData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.MonthlyData));
    const annualData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.AnnualData));
    
    let data;
    switch(period) {
        case 'weekly':
            data = weeklyData;
            break;
        case 'monthly':
            data = monthlyData;
            break;
        case 'annually':
            data = annualData;
            break;
    }
    
    showChart(period, data);
    updateStats(data);
}

function showChart(period, data) {
    const ctx = document.getElementById('fuelChart').getContext('2d');
    
    // Destroy existing chart if it exists
    if (currentChart) {
        currentChart.destroy();
    }
    
    currentChart = new Chart(ctx, {
        type: period === 'annually' ? 'bar' : 'line',
        data: {
            labels: data.map(d => d.Period),
            datasets: [
                {
                    label: 'Fuel Cost',
                    data: data.map(d => d.FuelCost),
                    borderColor: '#ff6b35',
                    backgroundColor: period === 'annually' ? '#ff6b35' : 'rgba(255, 107, 53, 0.1)',
                    borderWidth: period === 'annually' ? 1 : 3,
                    tension: period === 'annually' ? 0 : 0.4,
                    fill: period !== 'annually'
                }
            ]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            interaction: {
                mode: 'index',
                intersect: false,
            },
            scales: {
                x: {
                    display: true,
                    title: {
                        display: true,
                        text: period === 'weekly' ? 'Week' : period === 'monthly' ? 'Month' : 'Year'
                    },
                    grid: {
                        display: false
                    }
                },
                y: {
                    display: true,
                    title: {
                        display: true,
                        text: 'Amount (?)'
                    },
                    ticks: {
                        callback: function(value) {
                            return '?' + value.toLocaleString();
                        }
                    }
                }
            },
            plugins: {
                legend: {
                    display: false
                },
                tooltip: {
                    callbacks: {
                        label: function(context) {
                            let label = context.dataset.label || '';
                            if (label) {
                                label += ': ';
                            }
                            if (context.parsed.y !== null) {
                                label += '?' + context.parsed.y.toLocaleString('en-PH', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
                            }
                            return label;
                        }
                    }
                }
            }
        });
}

function updateStats(data) {
    const total = data.reduce((sum, d) => sum + d.FuelCost, 0);
    const average = total / data.length;
    const highest = Math.max(...data.map(d => d.FuelCost));
    const lowest = Math.min(...data.map(d => d.FuelCost));
    
    document.getElementById('totalFuelCost').textContent = '?' + total.toLocaleString('en-PH', { minimumFractionDigits: 0, maximumFractionDigits: 0 });
    document.getElementById('avgFuelCost').textContent = '?' + average.toLocaleString('en-PH', { minimumFractionDigits: 0, maximumFractionDigits: 0 });
    document.getElementById('highestFuelCost').textContent = '?' + highest.toLocaleString('en-PH', { minimumFractionDigits: 0, maximumFractionDigits: 0 });
    document.getElementById('lowestFuelCost').textContent = '?' + lowest.toLocaleString('en-PH', { minimumFractionDigits: 0, maximumFractionDigits: 0 });
}

function exportToPDF() {
    showNotification('Exporting to PDF...', 'info');
    setTimeout(() => {
        showNotification('PDF exported successfully!', 'success');
    }, 1000);
}

function exportToCSV() {
    showNotification('Exporting to CSV...', 'info');
    setTimeout(() => {
        showNotification('CSV exported successfully!', 'success');
    }, 1000);
}

function showNotification(message, type) {
    const notification = document.createElement('div');
    notification.className = `notification notification-${type}`;
    notification.innerHTML = `
        <i class="fas fa-${type === 'success' ? 'check-circle' : 'info-circle'}"></i>
        <span>${message}</span>
    `;
    
    document.body.appendChild(notification);
    
    setTimeout(() => {
        notification.remove();
    }, 3000);
}
</script>
</body>
</html>
