@model IEnumerable<RouteX.Models.FuelEntry>
@{
    ViewData["Title"] = "Fuel Management";
}

<div class="vehicles-container">
    <div class="vehicles-header">
        <p>Track and review fuel usage across your fleet</p>
    </div>

    <div class="vehicles-actions">
        <button class="btn btn-primary">
            <i class="fas fa-plus"></i>
            Add Fuel Entry
        </button>
        <div class="search-filter">
            <input type="text" class="form-control" placeholder="Search fuel logs...">
            <button class="btn btn-outline-secondary">
                <i class="fas fa-filter"></i>
            </button>
        </div>
    </div>

    <div class="vehicles-table-container">
        <table class="vehicles-table">
            <thead>
                <tr>
                    <th>Unit Model</th>
                    <th>Plate #</th>
                    <th>Date</th>
                    <th>Liters</th>
                    <th>Total Cost</th>
                    <th>Fuel Station</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var entry in Model)
                {
                    <tr>
                        <td>@entry.UnitModel</td>
                        <td>@entry.PlateNumber</td>
                        <td>@entry.Date.ToString("MMM dd, yyyy")</td>
                        <td>@entry.Liters.ToString("N1") L</td>
                        <td>@entry.TotalCost.ToString("C2")</td>
                        <td>@entry.FuelStation</td>
                        <td>
                            <div class="action-buttons">
                                <button class="action-btn edit-btn" title="Edit Entry">
                                    <i class="fas fa-edit"></i>
                                </button>
                                <button class="action-btn view-btn" title="View Details">
                                    <i class="fas fa-eye"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr>
                    <td colspan="7">
                        <div class="table-pagination">
                            <button class="page-link" type="button">&lt;</button>
                            <button class="page-link active" type="button">1</button>
                            <button class="page-link" type="button">&gt;</button>
                        </div>
                    </td>
                </tr>
            </tfoot>
        </table>
    </div>
</div>
