@model RouteX.Models.FinanceViewModel
@{
    ViewData["Title"] = "Finance";
    var expenseTypes = Model.ExpenseRecords.Select(e => e.ExpenseType).Distinct().ToList();
}

<style>
/* Reuse common popover/search styles from other pages */
.table-actions { display:flex; justify-content:space-between; align-items:center; gap:12px; margin-bottom:12px; }
.search-filter { position: relative; display:flex; align-items:center; gap:8px; }
.filter-popover {
    position: absolute;
    right: 0;
    top: calc(100% + 8px);
    width: 320px;
    background: #ffffff; /* white panel */
    border: 1px solid #eee;
    box-shadow: 0 6px 18px rgba(0,0,0,0.08);
    border-radius: 6px;
    padding: 12px;
    z-index: 1200;
    color: #111; /* black text */
}
.filter-popover::before {
    content: '';
    position: absolute;
    top: -8px;
    right: 16px;
    border-width: 8px 8px 0 8px;
    border-style: solid;
    border-color: #fff transparent transparent transparent;
}
.filter-row { display:flex; gap:12px; align-items:center; }
.filter-row > div { flex: 1; }
.filter-label { display:block; font-size:12px; margin-bottom:6px; color:#222; }
.filter-select, .filter-input { width:100%; padding:6px 8px; border:1px solid #ddd; border-radius:4px; }
.filter-actions { display:flex; gap:8px; justify-content:flex-end; margin-top:8px; }
.btn-apply { background:#ff7a00; color: #fff; border: none; padding:8px 12px; border-radius:4px; }
.btn-apply:hover { filter: brightness(0.95); }
.btn-clear { background:#111; color:#fff; border: none; padding:8px 12px; border-radius:4px; }
.btn-clear:hover { opacity:0.95; }
.pagination-info { color:#333; }
/* Expense type text colors, no background */
.expense-type-badge { background: transparent !important; padding: 0 !important; border: none !important; box-shadow: none !important; font-weight:600; }
.expense-fuel { color: #ff7a00 !important; }
.expense-maintenance { color: #ffb300 !important; }
.expense-other { color: #6c757d !important; }
</style>

<div class="vehicles-container">
    <div class="vehicles-header">
        <p>Track and analyze your fleet's financial performance</p>
    </div>

    <!-- Dashboard Summary Cards -->
    <div class="finance-summary-grid">
        <a href="@Url.Action("TotalExpensesAllTime", "Finance")" class="finance-card-link">
            <div class="finance-card clickable-card">
                <div class="finance-card-icon">
                    <i class="fas fa-money-bill-wave"></i>
                </div>
                <div class="finance-card-content">
                    <h3>@Model.Summary.TotalExpensesAllTime.ToString("C", new System.Globalization.CultureInfo("en-PH"))</h3>
                    <p>Total Expenses (All-Time)</p>
                </div>
            </div>
        </a>
        <a href="@Url.Action("TotalExpensesMonthly", "Finance")" class="finance-card-link">
            <div class="finance-card clickable-card">
                <div class="finance-card-icon">
                    <i class="fas fa-calendar-alt"></i>
                </div>
                <div class="finance-card-content">
                    <h3>@Model.Summary.TotalExpensesMonthly.ToString("C", new System.Globalization.CultureInfo("en-PH"))</h3>
                    <p>Total Expenses (Monthly)</p>
                </div>
            </div>
        </a>
        <a href="@Url.Action("TotalFuel", "Finance")" class="finance-card-link">
            <div class="finance-card clickable-card">
                <div class="finance-card-icon">
                    <i class="fas fa-gas-pump"></i>
                </div>
                <div class="finance-card-content">
                    <h3>@Model.Summary.TotalFuelCost.ToString("C", new System.Globalization.CultureInfo("en-PH"))</h3>
                    <p>Total Fuel Cost</p>
                </div>
            </div>
        </a>
        <a href="@Url.Action("TotalMaintenance", "Finance")" class="finance-card-link">
            <div class="finance-card clickable-card">
                <div class="finance-card-icon">
                    <i class="fas fa-wrench"></i>
                </div>
                <div class="finance-card-content">
                    <h3>@Model.Summary.TotalMaintenanceCost.ToString("C", new System.Globalization.CultureInfo("en-PH"))</h3>
                    <p>Total Maintenance Cost</p>
                </div>
            </div>
        </a>
    </div>

    <!-- Tables Section -->
    <div class="finance-section">
        <h3>Expense Records</h3>

        <div class="table-actions">
            <button class="btn btn-primary">
                <i class="fas fa-plus"></i>
                Add Expenses
            </button>

            <div class="search-filter">
                <input type="text" class="form-control" id="expenseSearch" placeholder="Search expenses...">
                <button id="expenseFilterToggle" class="btn btn-outline-secondary" title="Filters" type="button" aria-haspopup="true" aria-expanded="false">
                    <i class="fas fa-filter"></i>
                </button>

                <div id="expenseFilterPanel" class="filter-popover" role="dialog" aria-label="Expense filters" style="display:none;">
                    <div class="filter-row">
                        <div>
                            <label class="filter-label" for="expenseFilterStart">Start Date</label>
                            <input id="expenseFilterStart" class="filter-input" type="date" />
                        </div>
                        <div>
                            <label class="filter-label" for="expenseFilterEnd">End Date</label>
                            <input id="expenseFilterEnd" class="filter-input" type="date" />
                        </div>
                    </div>

                    <div style="margin-top:8px;">
                        <label class="filter-label" for="expenseFilterStatus">Status</label>
                        <select id="expenseFilterStatus" class="filter-select">
                            <option value="">All</option>
                            @foreach (var t in expenseTypes)
                            {
                                <option value="@t.ToLower()">@t</option>
                            }
                        </select>
                    </div>

                    <div class="filter-actions">
                        <button id="clearExpenseFilters" class="btn-clear" type="button">Clear</button>
                        <button id="applyExpenseFilters" class="btn-apply" type="button">Apply</button>
                    </div>
                </div>
            </div>
        </div>

        <div class="vehicles-table-container">
            <table class="vehicles-table">
                <thead>
                    <tr>
                        <th>Expense ID</th>
                        <th>Vehicle</th>
                        <th>Expense Type</th>
                        <th>Amount</th>
                        <th>Expense Date</th>
                        <th>Description</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody id="expenseTableBody">
                    @foreach (var expense in Model.ExpenseRecords)
                    {
                        <tr class="expense-row" data-vehicle="@expense.Vehicle.ToLower()" data-type="@expense.ExpenseType.ToLower()" data-desc="@expense.Description.ToLower()" data-date='@expense.ExpenseDate.ToString("yyyy-MM-dd")'>
                            <td>@expense.ExpenseId</td>
                            <td>@expense.Vehicle</td>
                            <td>
                                <span class="expense-type-badge expense-@expense.ExpenseType.ToLower()">
                                    @expense.ExpenseType
                                </span>
                            </td>
                            <td class="cost-highlight">@expense.Amount.ToString("C", new System.Globalization.CultureInfo("en-PH"))</td>
                            <td>@expense.ExpenseDate.ToString("MMM dd, yyyy")</td>
                            <td>@expense.Description</td>
                            <td>
                                <div class="action-buttons">
                                    <button class="action-btn edit-btn" title="Edit">
                                        <i class="fas fa-edit"></i>
                                    </button>
                                    <button class="action-btn view-btn" title="View">
                                        <i class="fas fa-eye"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr>
                        <td colspan="7">
                            <div class="table-pagination" style="display:flex; justify-content:space-between; align-items:center;">
                                <div class="pagination-info">Showing 0 of 0 entries</div>
                                <div class="pagination-controls">
                                    <button class="page-link prev" type="button">&lt;</button>
                                    <button class="page-link page-number active" type="button">1</button>
                                    <button class="page-link next" type="button">&gt;</button>
                                </div>
                            </div>
                        </td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>

</div>

<script>
document.addEventListener('DOMContentLoaded', function () {
    let currentPage = 1;
    const itemsPerPage = 10;
    const tbody = document.getElementById('expenseTableBody');
    const allRows = Array.from(tbody.getElementsByClassName('expense-row'));

    const filterToggle = document.getElementById('expenseFilterToggle');
    const filterPanel = document.getElementById('expenseFilterPanel');

    function openFilterPanel() { filterPanel.style.display = 'block'; filterToggle.setAttribute('aria-expanded', 'true'); }
    function closeFilterPanel() { filterPanel.style.display = 'none'; filterToggle.setAttribute('aria-expanded', 'false'); }

    document.addEventListener('click', function (e) { if (!filterPanel.contains(e.target) && !filterToggle.contains(e.target)) closeFilterPanel(); });

    function getFilteredRows() {
        const searchTerm = document.getElementById('expenseSearch').value.trim().toLowerCase();
        const start = document.getElementById('expenseFilterStart').value;
        const end = document.getElementById('expenseFilterEnd').value;
        const selectedType = document.getElementById('expenseFilterStatus').value || '';

        return allRows.filter(row => {
            const vehicle = (row.getAttribute('data-vehicle') || '').toLowerCase();
            const type = (row.getAttribute('data-type') || '').toLowerCase();
            const desc = (row.getAttribute('data-desc') || '').toLowerCase();
            const date = row.getAttribute('data-date');

            const matchesSearch = !searchTerm || vehicle.includes(searchTerm) || type.includes(searchTerm) || desc.includes(searchTerm);
            const matchesType = !selectedType || type === selectedType;

            let matchesDate = true;
            if (start) matchesDate = matchesDate && (date >= start);
            if (end) matchesDate = matchesDate && (date <= end);

            return matchesSearch && matchesType && matchesDate;
        });
    }

    function renderRowsForPage(rows) {
        allRows.forEach(r => r.style.display = 'none');
        const startIdx = (currentPage - 1) * itemsPerPage;
        const endIdx = startIdx + itemsPerPage;
        rows.forEach((r, i) => { if (i >= startIdx && i < endIdx) r.style.display = ''; });
    }

    function filterExpenses() { const filtered = getFilteredRows(); renderRowsForPage(filtered); updatePagination(filtered.length); }

    document.getElementById('expenseSearch').addEventListener('input', function () { currentPage = 1; filterExpenses(); });

    filterToggle.addEventListener('click', function (e) { e.stopPropagation(); if (filterPanel.style.display === 'block') closeFilterPanel(); else openFilterPanel(); });

    document.getElementById('applyExpenseFilters').addEventListener('click', function (e) { e.stopPropagation(); currentPage = 1; filterExpenses(); closeFilterPanel(); });
    document.getElementById('clearExpenseFilters').addEventListener('click', function (e) { e.stopPropagation(); document.getElementById('expenseFilterStart').value = ''; document.getElementById('expenseFilterEnd').value = ''; document.getElementById('expenseFilterStatus').value = ''; currentPage = 1; filterExpenses(); closeFilterPanel(); });

    document.querySelector('.pagination-controls .prev').addEventListener('click', function () { if (currentPage > 1) { currentPage--; filterExpenses(); } });
    document.querySelector('.pagination-controls .next').addEventListener('click', function () { const totalVisible = getFilteredRows().length; const maxPage = Math.max(1, Math.ceil(totalVisible / itemsPerPage)); if (currentPage < maxPage) { currentPage++; filterExpenses(); } });

    function updatePagination(visibleCount) {
        const info = document.querySelector('.pagination-info');
        const start = (currentPage - 1) * itemsPerPage + 1;
        const end = Math.min(visibleCount, currentPage * itemsPerPage);
        info.textContent = visibleCount === 0 ? 'Showing 0 of 0 entries' : `Showing ${start}-${end} of ${visibleCount} entries`;

        const prevBtn = document.querySelector('.pagination-controls .prev');
        const nextBtn = document.querySelector('.pagination-controls .next');
        prevBtn.style.display = currentPage > 1 ? '' : 'none';
        nextBtn.style.display = visibleCount > currentPage * itemsPerPage ? '' : 'none';

        const pageNumberBtn = document.querySelector('.pagination-controls .page-number');
        pageNumberBtn.textContent = currentPage.toString();
    }

    currentPage = 1; filterExpenses();
});
</script>

