@model IEnumerable<RouteX.Models.Vehicle>
@{
    ViewData["Title"] = "Vehicle Management";
}

<div class="vehicles-container">
    <div class="vehicles-header">
        <p>Manage and monitor your vehicle fleet</p>
    </div>

    <div class="vehicles-actions">
        <button class="btn btn-primary">
            <i class="fas fa-plus"></i>
            Add New Vehicle
        </button>
        <div class="search-filter">
            <input type="text" class="form-control" id="vehicleSearch" placeholder="Search vehicles...">
        </div>
    </div>

    <div class="vehicles-table-container">
        <table class="vehicles-table">
            <thead>
                <tr>
                    <th>Vehicle ID</th>
                    <th>Unit Model</th>
                    <th>Plate #</th>
                    <th>Vehicle Type</th>
                    <th>Status</th>
                    <th>Mileage</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody id="vehicleTableBody">
                @foreach (var vehicle in Model)
                {
                    <tr class="vehicle-row" data-model="@vehicle.UnitModel.ToLower()" data-plate="@vehicle.PlateNumber.ToLower()" data-type="@vehicle.VehicleType.ToLower()" data-status="@vehicle.Status.ToString()">
                        <td>@vehicle.Id</td>
                        <td>@vehicle.UnitModel</td>
                        <td>@vehicle.PlateNumber</td>
                        <td>@vehicle.VehicleType</td>
                        <td>
                            <span class="status-badge status-@vehicle.Status.ToString().ToLower()">
                                @vehicle.Status
                            </span>
                        </td>
                        <td>@vehicle.Mileage.ToString("N0") km</td>
                        <td>
                            <div class="action-buttons">
                                <button class="action-btn edit-btn" title="Edit Vehicle">
                                    <i class="fas fa-edit"></i>
                                </button>
                                <button class="action-btn view-btn" title="View Details">
                                    <i class="fas fa-eye"></i>
                                </button>
                                <button class="action-btn route-btn" title="View Route">
                                    <i class="fas fa-route"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr>
                    <td colspan="7">
                        <div class="table-pagination">
                            <button class="page-link" type="button">&lt;</button>
                            <button class="page-link active" type="button">1</button>
                            <button class="page-link" type="button">&gt;</button>
                        </div>
                    </td>
                </tr>
            </tfoot>
        </table>
    </div>
</div>

<script>
let currentPage = 1;
const itemsPerPage = 10;
const allVehicles = @Html.Raw(Json.Serialize(Model));

function filterVehicles() {
    const searchTerm = document.getElementById('vehicleSearch').value.toLowerCase();
    const tbody = document.getElementById('vehicleTableBody');
    const rows = tbody.getElementsByClassName('vehicle-row');
    
    let visibleCount = 0;
    for (let i = 0; i < rows.length; i++) {
        const row = rows[i];
        const model = row.getAttribute('data-model').toLowerCase();
        const plate = row.getAttribute('data-plate').toLowerCase();
        const type = row.getAttribute('data-type').toLowerCase();
        const status = row.getAttribute('data-status');
        
        const matchesSearch = !searchTerm || model.includes(searchTerm) || plate.includes(searchTerm) || type.includes(searchTerm);
        
        if (matchesSearch) {
            row.style.display = '';
            visibleCount++;
            if (visibleCount <= itemsPerPage) {
                row.classList.remove('hidden-page');
            } else {
                row.classList.add('hidden-page');
            }
        } else {
            row.style.display = 'none';
        }
    }
    
    updatePagination(visibleCount);
}

// Auto-filter on search input - automatically filters as you type
document.getElementById('vehicleSearch').addEventListener('input', function() {
    filterVehicles();
});

function updatePagination(visibleCount) {
    const paginationInfo = document.querySelector('.pagination-info');
    const showingCount = Math.min(visibleCount, itemsPerPage);
    paginationInfo.textContent = `Showing 1-${showingCount} of ${visibleCount} entries`;
    
    const nextBtn = document.querySelector('.pagination-controls button:last-child');
    if (visibleCount <= itemsPerPage) {
        nextBtn.style.display = 'none';
    } else {
        nextBtn.style.display = '';
    }
}
</script>
