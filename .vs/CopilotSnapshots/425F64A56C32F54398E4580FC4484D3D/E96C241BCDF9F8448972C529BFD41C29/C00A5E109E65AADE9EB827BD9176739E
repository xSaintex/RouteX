<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - RouteX</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/RouteX.styles.css" asp-append-version="true" />
</head>
<body>
    <div class="app-container">
        <!-- Sidebar -->
        <nav class="sidebar" id="sidebar">
            <div class="sidebar-header">
                <div class="sidebar-brand-container">
                    <img src="~/routexlogo.png" alt="RouteX Logo" class="sidebar-logo" id="sidebarLogoToggle" />
                    <span class="sidebar-brand">
                        <span class="route-text">Route</span><span class="x-text">X</span>
                    </span>
                </div>
                <button class="sidebar-collapse-btn" id="sidebarCollapseBtn">
                    <i class="fas fa-chevron-left"></i>
                </button>
            </div>
            
            <ul class="sidebar-menu">
                <li class="menu-item">
                    <a href="@Url.Action("Index", "Home")" class="menu-link @(ViewData["Title"]?.ToString() == "Dashboard" ? "active" : "")">
                        <i class="fas fa-tachometer-alt menu-icon"></i>
                        <span class="menu-text">Dashboard</span>
                    </a>
                </li>
                <li class="menu-item">
                    <a href="@Url.Action("VehiclePage", "Vehicles")" class="menu-link @(ViewData["Title"]?.ToString() == "Vehicle Management" ? "active" : "")">
                        <i class="fas fa-truck menu-icon"></i>
                        <span class="menu-text">Vehicles</span>
                    </a>
                </li>
                <li class="menu-item">
                    <a href="@Url.Action("FuelPage", "Fuel")" class="menu-link @(ViewData["Title"]?.ToString() == "Fuel Management" ? "active" : "")">
                        <i class="fas fa-gas-pump menu-icon"></i>
                        <span class="menu-text">Fuel</span>
                    </a>
                </li>
                <li class="menu-item">
                    <a href="@Url.Action("MaintenancePage", "Maintenance")" class="menu-link @(ViewData["Title"]?.ToString() == "Maintenance Schedule" ? "active" : "")">
                        <i class="fas fa-wrench menu-icon"></i>
                        <span class="menu-text">Maintenance</span>
                    </a>
                </li>
                <li class="menu-item">
                    <a href="@Url.Action("FinancePage", "Finance")" class="menu-link @(ViewData["Title"]?.ToString() == "Finance" ? "active" : "")">
                        <i class="fas fa-dollar-sign menu-icon"></i>
                        <span class="menu-text">Finance</span>
                    </a>
                </li>
                <li class="menu-item">
                    <a href="@Url.Action("ReportsPage", "Reports")" class="menu-link @(ViewData["Title"]?.ToString() == "Reports" ? "active" : "")">
                        <i class="fas fa-chart-bar menu-icon"></i>
                        <span class="menu-text">Reports</span>
                    </a>
                </li>
                <li class="menu-item">
                    <a href="@Url.Action("AuditPage", "Audit")" class="menu-link @(ViewData["Title"]?.ToString() == "Audit Logs" ? "active" : "")">
                        <i class="fas fa-clipboard-list menu-icon"></i>
                        <span class="menu-text">Audit</span>
                    </a>
                </li>
                <li class="menu-item">
                    <a href="@Url.Action("RolesPage", "Roles")" class="menu-link @(ViewData["Title"]?.ToString() == "Roles" ? "active" : "")">
                        <i class="fas fa-user-tag menu-icon"></i>
                        <span class="menu-text">Roles</span>
                    </a>
                </li>
                <li class="menu-item">
                    <a href="@Url.Action("UsersPage", "Users")" class="menu-link @(ViewData["Title"]?.ToString() == "Users List" ? "active" : "")">
                        <i class="fas fa-users menu-icon"></i>
                        <span class="menu-text">Users</span>
                    </a>
                </li>
            </ul>
            
            <div class="sidebar-footer">
                <a href="#" class="logout-btn">
                    <i class="fas fa-sign-out-alt menu-icon"></i>
                    <span class="menu-text">Logout</span>
                </a>
            </div>
        </nav>

        <!-- Main Content Area -->
        <div class="main-content">
            <!-- Topbar -->
            <header class="topbar">
                <div class="topbar-content">
                    <h1 class="page-title">@ViewData["Title"]</h1>
                    <div class="topbar-actions">
                        <div class="user-menu">
                            <i class="fas fa-user-circle user-avatar"></i>
                            <span class="user-name">Admin User</span>
                        </div>
                    </div>
                </div>
            </header>

            <!-- Page Content -->
            <main class="content-area">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        const sidebar = document.getElementById('sidebar');
        const collapseIcon = document.querySelector('#sidebarCollapseBtn i');

        document.addEventListener('DOMContentLoaded', function() {
            const isCollapsed = localStorage.getItem('sidebarCollapsed') === 'true';
            if (isCollapsed) {
                sidebar.classList.add('collapsed');
                collapseIcon.classList.remove('fa-chevron-left');
                collapseIcon.classList.add('fa-chevron-right');
            }
        });

        document.getElementById('sidebarCollapseBtn').addEventListener('click', function() {
            toggleSidebar();
        });

        document.getElementById('sidebarLogoToggle').addEventListener('click', function() {
            if (sidebar.classList.contains('collapsed')) {
                toggleSidebar();
            }
        });

        function toggleSidebar() {
            sidebar.classList.toggle('collapsed');
            const isCollapsed = sidebar.classList.contains('collapsed');
            localStorage.setItem('sidebarCollapsed', isCollapsed.toString());

            if (isCollapsed) {
                collapseIcon.classList.remove('fa-chevron-left');
                collapseIcon.classList.add('fa-chevron-right');
            } else {
                collapseIcon.classList.remove('fa-chevron-right');
                collapseIcon.classList.add('fa-chevron-left');
            }
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
