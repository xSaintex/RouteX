        }

        [HttpPost]
        [ValidateAntiForgeryToken]
        public async Task<IActionResult> RestoreTrip(int id)
        {
            if (!await ColumnExistsAsync("RouteTrips", "IsArchived"))
            {
                TempData["Error"] = "RouteTrips archive column is missing. Please add it before restoring.";
                return RedirectToAction(nameof(ArchivePage));
            }

            var sql = "UPDATE RouteTrips SET IsArchived = 0, ArchivedAt = NULL WHERE Id = @Id";
            await _context.Database.ExecuteSqlRawAsync(sql, new SqlParameter("@Id", id));

            TempData["Success"] = "Trip restored successfully.";
            return RedirectToAction(nameof(ArchivePage));
        }

        [HttpPost]
        [ValidateAntiForgeryToken]
        public async Task<IActionResult> RestoreUser(int id)
        {
            var user = await _context.Users.AsNoTracking().FirstOrDefaultAsync(u => u.UserId == id);
            if (user == null)
            {
                TempData["Error"] = "User not found.";
                return RedirectToAction(nameof(ArchivePage));
            }

            var status = await GetArchivedUserStatusAsync(id) ?? UserStatus.Active.ToString();
            var sql = "UPDATE Users SET Status = @Status WHERE UserId = @UserId";
            await _context.Database.ExecuteSqlRawAsync(sql,
                new SqlParameter("@Status", status),
                new SqlParameter("@UserId", id));

            TempData["Success"] = $"{user.FirstName} {user.LastName} restored successfully.";
            return RedirectToAction(nameof(ArchivePage));
        }

        [HttpPost]
        [ValidateAntiForgeryToken]
        public async Task<IActionResult> RestoreBudget(int id)
        {
            var entry = await _context.BudgetEntries.FindAsync(id);
            if (entry == null)
            {
                return RedirectToAction(nameof(ArchivePage));
            }

            entry.IsActive = true;
            await _context.SaveChangesAsync();

            TempData["Success"] = "Budget restored successfully.";
            return RedirectToAction(nameof(ArchivePage));
        }

        private async Task<string?> GetArchivedUserStatusAsync(int userId)
        {
            var prefix = $"Archive:User:{userId}:Status:";
            var log = await _context.AuditLogs
                .AsNoTracking()
                .Where(l => l.Action.StartsWith(prefix))
                .OrderByDescending(l => l.ActionDate)
                .FirstOrDefaultAsync();

            if (log == null)
            {
                return null;
            }

            return log.Action.Substring(prefix.Length);
        }

        private async Task<int?> GetArchivedVehicleStatusAsync(int vehicleId)
        {
            var prefix = $"Archive:Vehicle:{vehicleId}:Status:";
            var log = await _context.AuditLogs
                .AsNoTracking()
                .Where(l => l.Action.StartsWith(prefix))
                .OrderByDescending(l => l.ActionDate)
                .FirstOrDefaultAsync();

            if (log == null)
            {
                return null;
            }

            if (int.TryParse(log.Action.Substring(prefix.Length), out var status))
            {
                return status;
            }

            return null;
        }

        private async Task<int?> GetArchivedMaintenanceStatusAsync(int maintenanceId)
        {
            var prefix = $"Archive:Maintenance:{maintenanceId}:Status:";
            var log = await _context.AuditLogs
                .AsNoTracking()
                .Where(l => l.Action.StartsWith(prefix))
                .OrderByDescending(l => l.ActionDate)
                .FirstOrDefaultAsync();

            if (log == null)
            {
                return null;
            }

            if (int.TryParse(log.Action.Substring(prefix.Length), out var status))
            {
                return status;
            }

            return null;
        }

        private static string GetArchiveLogKey(string action)
        {
            if (string.IsNullOrWhiteSpace(action))
            {
                return string.Empty;
            }

            var parts = action.Split(':', StringSplitOptions.RemoveEmptyEntries);
            if (parts.Length >= 3 && parts[0] == "Archive")
            {
                return $"Archive:{parts[1]}:{parts[2]}";
            }

            return action;
        }

        private async Task<bool> ColumnExistsAsync(string tableName, string columnName)
        {
            const string sql = @"SELECT COUNT(*) AS Value
                                 FROM INFORMATION_SCHEMA.COLUMNS
                                 WHERE TABLE_NAME = @TableName AND COLUMN_NAME = @ColumnName";

            try
            {
                var result = await _context.Database.SqlQueryRaw<int>(
                        sql,
                        new SqlParameter("@TableName", tableName),
                        new SqlParameter("@ColumnName", columnName))
                    .FirstOrDefaultAsync();
                return result > 0;
            }
            catch
            {
                return false;
            }
        }
    }
}
