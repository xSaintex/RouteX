@model IEnumerable<RouteX.Models.FuelEntry>
@{
    ViewData["Title"] = "Fuel Management";
    var fuelTypes = Model.Select(e => e.FuelStation).Distinct().ToList();
    var dates = Model.Select(e => e.Date.Date).Distinct().ToList();
}

<style>
/* Filter popover and pagination styles (reuse from other pages) */
.search-filter { position: relative; display:flex; align-items:center; gap:8px; }
.filter-popover {
    position: absolute;
    right: 0;
    top: calc(100% + 8px);
    width: 320px;
    background: #ffffff;
    border: 1px solid #eee;
    box-shadow: 0 6px 18px rgba(0,0,0,0.08);
    border-radius: 6px;
    padding: 12px;
    z-index: 1200;
    color: #111;
}
.filter-popover::before { content: ''; position: absolute; top: -8px; right: 16px; border-width: 8px 8px 0 8px; border-style: solid; border-color: #fff transparent transparent transparent; }
.filter-label { display:block; font-size:12px; margin-bottom:6px; color:#222; }
.filter-select, .filter-input { width:100%; padding:6px 8px; border:1px solid #ddd; border-radius:4px; }
.filter-actions { display:flex; gap:8px; justify-content:flex-end; margin-top:8px; }
.btn-apply { background:#ff7a00; color: #fff; border: none; padding:8px 12px; border-radius:4px; }
.btn-clear { background:#111; color:#fff; border: none; padding:8px 12px; border-radius:4px; }

.table-pagination { display:flex; justify-content:space-between; align-items:center; gap:8px; margin-top:12px; }
.pagination-info { color:#333; font-size:14px; }
.table-pagination .page-link { border: 1px solid rgba(0,0,0,0.08); background: #fff; color:#111; padding:6px 10px; border-radius:6px; cursor:pointer; }
.table-pagination .page-link.prev, .table-pagination .page-link.next { min-width:32px; }
</style>

<div class="vehicles-container">
    <div class="vehicles-header">
        <p>Track and review fuel usage across your fleet</p>
    </div>

    <div class="vehicles-actions">
        <a href="@Url.Action("AddFuel", "Fuel")" class="btn btn-primary">
            <i class="fas fa-plus"></i>
            Add Fuel Entry
        </a>
        <div class="search-filter">
            <input type="text" class="form-control" id="fuelSearch" placeholder="Search fuel logs...">
            <button id="fuelFilterToggle" class="btn btn-outline-secondary" title="Filters" type="button" aria-haspopup="true" aria-expanded="false">
                <i class="fas fa-filter"></i>
            </button>

            <div id="fuelFilterPanel" class="filter-popover" role="dialog" aria-label="Fuel filters" style="display:none;">
                <div>
                    <label class="filter-label" for="filterStation">Fuel Station</label>
                    <select id="filterStation" class="filter-select">
                        <option value="">All</option>
                        @foreach (var station in fuelTypes)
                        {
                            <option value="@station.ToLower()">@station</option>
                        }
                    </select>
                </div>

                <div style="margin-top:8px;">
                    <label class="filter-label" for="filterStartDate">Start Date</label>
                    <input type="date" id="filterStartDate" class="filter-input" />
                </div>

                <div style="margin-top:8px;">
                    <label class="filter-label" for="filterEndDate">End Date</label>
                    <input type="date" id="filterEndDate" class="filter-input" />
                </div>

                <div class="filter-actions">
                    <button id="clearFuelFilters" class="btn-clear" type="button">Clear</button>
                    <button id="applyFuelFilters" class="btn-apply" type="button">Apply</button>
                </div>
            </div>
        </div>
    </div>

    <div class="vehicles-table-container">
        <table class="vehicles-table">
            <thead>
                <tr>
                    <th>Unit Model</th>
                    <th>Plate #</th>
                    <th>Date</th>
                    <th>Liters</th>
                    <th>Total Cost</th>
                    <th>Fuel Station</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var entry in Model)
                {
                    <tr>
                        <td>@entry.UnitModel</td>
                        <td>@entry.PlateNumber</td>
                        <td>@entry.Date.ToString("MMM dd, yyyy")</td>
                        <td>@entry.Liters.ToString("N1") L</td>
                        <td>@entry.TotalCost.ToString("C2")</td>
                        <td>@entry.FuelStation</td>
                        <td>
                            <div class="action-buttons">
                                <a href="@Url.Action("EditFuel", "Fuel", new { id = entry.Id })" class="action-btn edit-btn" title="Edit Entry">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <button class="action-btn view-btn" title="View Details">
                                    <i class="fas fa-eye"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr>
                    <td colspan="7">
                        <div class="table-pagination" style="display:flex; justify-content:space-between; align-items:center;">
                            <div class="pagination-info">Showing 0 of 0 entries</div>
                            <div class="pagination-controls">
                                <button class="page-link prev" type="button">&lt;</button>
                                <button class="page-link page-number active" type="button">1</button>
                                <button class="page-link next" type="button">&gt;</button>
                            </div>
                        </div>
                    </td>
                </tr>
            </tfoot>
        </table>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const filterToggle = document.getElementById('fuelFilterToggle');
    const filterPanel = document.getElementById('fuelFilterPanel');
    const searchInput = document.getElementById('fuelSearch');
    const tableBody = document.querySelector('.vehicles-table tbody');
    const rows = Array.from(tableBody.querySelectorAll('tr'));
    let currentPage = 1;
    const itemsPerPage = 10;

    function openFilterPanel() {
        filterPanel.style.display = 'block';
        filterToggle.setAttribute('aria-expanded', 'true');
    }

    function closeFilterPanel() {
        filterPanel.style.display = 'none';
        filterToggle.setAttribute('aria-expanded', 'false');
    }

    // Close filter when clicking outside
    document.addEventListener('click', function(e) {
        if (!filterPanel.contains(e.target) && e.target !== filterToggle) {
            closeFilterPanel();
        }
    });

    function getFilteredRows() {
        const searchTerm = searchInput.value.toLowerCase();
        const stationFilter = document.getElementById('filterStation').value.toLowerCase();
        const startDate = document.getElementById('filterStartDate').value;
        const endDate = document.getElementById('filterEndDate').value;

        return rows.filter(row => {
            const cells = row.querySelectorAll('td');
            const unitModel = cells[0].textContent.toLowerCase();
            const plateNumber = cells[1].textContent.toLowerCase();
            const dateText = cells[2].textContent;
            const fuelStation = cells[5].textContent.toLowerCase();

            // Search filter
            const matchesSearch = !searchTerm || 
                unitModel.includes(searchTerm) || 
                plateNumber.includes(searchTerm) || 
                fuelStation.includes(searchTerm);

            // Station filter
            const matchesStation = !stationFilter || fuelStation.includes(stationFilter);

            // Date range filter
            let matchesDate = true;
            if (startDate || endDate) {
                const rowDate = new Date(dateText);
                if (startDate) {
                    const start = new Date(startDate);
                    matchesDate = matchesDate && rowDate >= start;
                }
                if (endDate) {
                    const end = new Date(endDate);
                    end.setHours(23, 59, 59, 999); // Include the entire end date
                    matchesDate = matchesDate && rowDate <= end;
                }
            }

            return matchesSearch && matchesStation && matchesDate;
        });
    }

    function renderRowsForPage(filteredRows) {
        const start = (currentPage - 1) * itemsPerPage;
        const end = start + itemsPerPage;
        const pageRows = filteredRows.slice(start, end);

        rows.forEach(row => row.style.display = 'none');
        pageRows.forEach(row => row.style.display = '');
    }

    function updatePagination(visibleCount) {
        const info = document.querySelector('.pagination-info');
        const start = (currentPage - 1) * itemsPerPage + 1;
        const end = Math.min(visibleCount, currentPage * itemsPerPage);
        info.textContent = visibleCount === 0 ? 'Showing 0 of 0 entries' : `Showing ${start}-${end} of ${visibleCount} entries`;

        const prevBtn = document.querySelector('.pagination-controls .prev');
        const nextBtn = document.querySelector('.pagination-controls .next');
        // hide/show prev/next like maintenance page
        prevBtn.style.display = currentPage > 1 ? '' : 'none';
        nextBtn.style.display = visibleCount > currentPage * itemsPerPage ? '' : 'none';

        const pageNumberBtn = document.querySelector('.pagination-controls .page-number');
        if (pageNumberBtn) pageNumberBtn.textContent = currentPage.toString();
    }

    function filterFuel() {
        const filtered = getFilteredRows();
        renderRowsForPage(filtered);
        updatePagination(filtered.length);
    }

    // Auto-filter on search input
    searchInput.addEventListener('input', function () {
        currentPage = 1;
        filterFuel();
    });

    filterToggle.addEventListener('click', function (e) {
        e.stopPropagation();
        if (filterPanel.style.display === 'block') closeFilterPanel(); else openFilterPanel();
    });

    document.getElementById('applyFuelFilters').addEventListener('click', function (e) {
        e.stopPropagation();
        currentPage = 1;
        filterFuel();
        closeFilterPanel();
    });

    document.getElementById('clearFuelFilters').addEventListener('click', function (e) {
        e.stopPropagation();
        document.getElementById('filterStation').value = '';
        document.getElementById('filterStartDate').value = '';
        document.getElementById('filterEndDate').value = '';
        currentPage = 1;
        filterFuel();
        closeFilterPanel();
    });

    // pagination
    document.querySelector('.pagination-controls .prev').addEventListener('click', function () {
        if (currentPage > 1) { currentPage--; filterFuel(); }
    });

    document.querySelector('.pagination-controls .next').addEventListener('click', function () {
        const totalVisible = getFilteredRows().length;
        const maxPage = Math.max(1, Math.ceil(totalVisible / itemsPerPage));
        if (currentPage < maxPage) { currentPage++; filterFuel(); }
    });

    // Initial load
    currentPage = 1;
    filterFuel();
});
</script>
